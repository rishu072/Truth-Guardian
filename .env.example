# ─── Django Backend ─────────────────────────────────────────────
DJANGO_SECRET_KEY=your-django-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ───────────────────────────────────────────────────
# Leave empty to use SQLite (default for development).
# For PostgreSQL, use: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# ─── Google Gemini AI ───────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ─── Google Custom Search ──────────────────────────────────────
SEARCH_ENGINE_API_KEY=your-google-search-api-key-here
CX=your-custom-search-engine-id-here

# ─── CORS (comma-separated origins) ───────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,chrome-extension://your-extension-id

# ─── Next.js Frontend (.env.local in website/) ────────────────
# DJANGO_API_BASE=http://localhost:8000
# EXTENSION=chrome-extension://your-extension-id
# BROWSER=http://localhost:3000
# NEXT_PUBLIC_GA_ID=your-ga-id
# NEXT_PUBLIC_FACEBOOK_APP_ID=your-fb-app-id
# GEMINI_API_KEY=your-gemini-api-key-here
# GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-04-17:generateContent
# SEARCH_ENGINE_API_KEY=your-google-search-api-key-here
# CX=your-custom-search-engine-id-here
